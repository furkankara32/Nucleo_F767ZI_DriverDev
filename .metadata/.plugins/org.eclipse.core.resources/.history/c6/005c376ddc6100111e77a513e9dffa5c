{
	if (pUSARTx == USART1)
	{
		return s_USART1Handle;
	}
	else if (pUSARTx == USART2)
	{
		return s_USART2Handle;
	}
	else if (pUSARTx == USART3)
	{
		return s_USART3Handle;
	}
	else if (pUSARTx == UART4)
	{
		return s_UART4Handle;
	}
	else if (pUSARTx == UART5)
	{
		return s_UART5Handle;
	}
	else if (pUSARTx == USART6)
	{
		return s_USART6Handle;
	}
	else if (pUSARTx == UART7)
	{
		return s_UART7Handle;
	}
	else if (pUSARTx == UART8)
