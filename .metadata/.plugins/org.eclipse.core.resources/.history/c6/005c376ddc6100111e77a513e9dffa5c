static uint8_t USART_WaitOnFlagUntilTimeout(USART_RegDef_t *pUSARTx,uint32_t FlagName,uint8_t DesiredStatus,uint32_t TimeoutMs)
{
	uint32_t start_tick = millis();

	while(USART_GetFlagStatus(pUSARTx, FlagName) != DesiredStatus)
	{
		if((millis() - start_tick) >= TimeoutMs)
		{
			return USART_STATUS_TIMEOUT;
		}

	}

	return USART_STATUS_OK;
}

static uint32_t USART_ComputeBRR(uint32_t PeripheralClockHz, uint32_t BaudRate,uint8_t Oversampling)
{
	uint32_t usartdiv;
	uint32_t brr;

	if (BaudRate == 0U)
	{
		return 0U;
	}

	if (Oversampling == USART_OVERSAMPLING_8)
	{
		/*
		 * OVER8 = 1
		 * USARTDIV = 2 * fCK / baud
		 */
		usartdiv = ((2U * PeripheralClockHz) + (BaudRate / 2U)) / BaudRate;

		/*
		 * BRR[15:4] = USARTDIV[15:4]
		 * BRR[3]    = 0
		 * BRR[2:0]  = USARTDIV[3:0] >> 1
		 */
		brr = (usartdiv & 0xFFF0U) | ((usartdiv & 0x000FU) >> 1U);
		brr &= ~(1U << 3U);
	}
	else
	{
		/*
		 * OVER8 = 0
		 * USARTDIV = fCK / baud
		 * BRR = USARTDIV
		 */
		brr = (PeripheralClockHz + (BaudRate / 2U)) / BaudRate;
	}

	return (brr & 0xFFFFU);
}
static uint32_t USART_GetPeripheralClock(USART_RegDef_t *pUSARTx)
{
	if ((pUSARTx == USART1) || (pUSARTx == USART6))
	{
		return RCC_GetPCLK2Value();
	}
	else
	{
		return RCC_GetPCLK1Value();
	}
}
static void USART_SetBaudRate(USART_RegDef_t *pUSARTx,uint32_t PeripheralClockHz,uint32_t BaudRate,uint8_t Oversampling)
{
	uint32_t brr_value;

	brr_value = USART_ComputeBRR(PeripheralClockHz, BaudRate, Oversampling);

	pUSARTx->USART_BRR = (brr_value & 0xFFFFU);
}
static void USART_RegisterHandle(USART_Handle_t *pUSARTHandle)
{
	if (pUSARTHandle->pUSARTx == USART1)
	{
		s_USART1Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == USART2)
	{
		s_USART2Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == USART3)
	{
		s_USART3Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == UART4)
	{
		s_UART4Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == UART5)
	{
		s_UART5Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == USART6)
	{
		s_USART6Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == UART7)
	{
		s_UART7Handle = pUSARTHandle;
	}
	else if (pUSARTHandle->pUSARTx == UART8)
	{
		s_UART8Handle = pUSARTHandle;
	}
}

