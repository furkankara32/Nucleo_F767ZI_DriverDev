#ifndef MYDRIVERS_INC_STM32F767XX_USART_DRIVER_H_
#define MYDRIVERS_INC_STM32F767XX_USART_DRIVER_H_
#include "stm32f767xx.h"

/*
 * USART return status
 */
#define USART_STATUS_OK              0U
#define USART_STATUS_TIMEOUT         1U
#define USART_STATUS_ERROR           2U
#define USART_STATUS_TXE_TIMEOUT     3U
#define USART_STATUS_TC_TIMEOUT      4U
#define USART_STATUS_RXNE_TIMEOUT    5U
#define USART_STATUS_NO_DATA         6U
#define USART_STATUS_TEACK_TIMEOUT   7U
#define USART_STATUS_REACK_TIMEOUT   8U
/*
 * USART mode
 */
#define USART_MODE_ONLY_TX       0U
#define USART_MODE_ONLY_RX       1U
#define USART_MODE_TXRX          2U

/*
 * USART oversampling
 */
#define USART_OVERSAMPLING_16    0U
#define USART_OVERSAMPLING_8     1U

/*
 * USART word length
 */
#define USART_WORDLEN_7BITS      7U
#define USART_WORDLEN_8BITS      8U
#define USART_WORDLEN_9BITS      9U

/*
 * USART stop bits
 */
#define USART_STOPBITS_1         0U
#define USART_STOPBITS_0_5       1U
#define USART_STOPBITS_2         2U
#define USART_STOPBITS_1_5       3U

/*
 * USART parity control
 */
#define USART_PARITY_DISABLE     0U
#define USART_PARITY_EVEN        1U
#define USART_PARITY_ODD         2U

/*
 * USART Interrupt
 */
#define USART_INTERRUPT_RXNE         0U
#define USART_INTERRUPT_TXE          1U
#define USART_INTERRUPT_TC           2U
#define USART_INTERRUPT_PE           3U
#define USART_INTERRUPT_ERR          4U

/*
 * USART Events
 */
#define USART_EVENT_RX_BYTE_RECEIVED  0U
#define USART_EVENT_RX_OVERFLOW       1U
#define USART_EVENT_PARITY_ERROR      2U
#define USART_EVENT_FRAME_ERROR       3U
#define USART_EVENT_NOISE_ERROR       4U
#define USART_EVENT_OVERRUN_ERROR     5U

typedef struct
{
	uint8_t USART_Mode;
	uint32_t USART_Baud;
	uint8_t USART_WordLength;
	uint8_t USART_StopBits;
	uint8_t USART_ParityControl;
	uint8_t USART_Oversampling;
	/*
	 * For now we pass peripheral clock manually.
	 * Default reset clock is usually 16 MHz.
	 */
	uint32_t USART_PeripheralClockHz;

} USART_Config_t;

typedef struct
{
	USART_RegDef_t *pUSARTx;
	USART_Config_t USART_Config;
	uint8_t *pRxRingBuffer;
	uint16_t RxRingBufferSize;
	volatile uint16_t RxHead;
	volatile uint16_t RxTail;
	volatile uint8_t RxOverflow;
} USART_Handle_t;

/*
 * Peripheral clock setup
 */
void USART_PeriClockControl(USART_RegDef_t *pUSARTx, uint8_t EnorDi);

/*
 * Init / DeInit
 */
uint8_t USART_Init(USART_Handle_t *pUSARTHandle);
void USART_DeInit(USART_RegDef_t *pUSARTx);

/*
 * Peripheral control
 */
void USART_PeripheralControl(USART_RegDef_t *pUSARTx, uint8_t EnorDi);

/*
 * Data send / receive with timeout
 */
uint8_t USART_SendDataWithTimeout(USART_Handle_t *pUSARTHandle,
								  uint8_t *pTxBuffer,
								  uint32_t Len,
								  uint32_t TimeoutMs);

uint8_t USART_ReceiveDataWithTimeout(USART_Handle_t *pUSARTHandle,
									 uint8_t *pRxBuffer,
									 uint32_t Len,
									 uint32_t TimeoutMs);

/*
 * Flag status
 */
uint8_t USART_GetFlagStatus(USART_RegDef_t *pUSARTx, uint32_t FlagName);

/*
 * USART Interrupt
 */
void USART_PeripheralInterruptControl(USART_RegDef_t *pUSARTx,
									  uint8_t InterruptName,
									  uint8_t EnorDi);

void USART_IRQHandling(USART_RegDef_t *pUSARTx);

uint8_t USART_RxRingBufferInit(USART_Handle_t *pUSARTHandle,
							   uint8_t *pBuffer,
							   uint16_t Size);

uint16_t USART_RxAvailable(USART_Handle_t *pUSARTHandle);

uint8_t USART_RxReadByte(USART_Handle_t *pUSARTHandle,
						 uint8_t *pData);
uint16_t USART_RxReadBytes(USART_Handle_t *pUSARTHandle,
						   uint8_t *pBuffer,
						   uint16_t Len);
void USART_ApplicationEventCallback(USART_Handle_t *pUSARTHandle,
									uint8_t Event);

#endif /* MYDRIVERS_INC_STM32F767XX_USART_DRIVER_H_ */
